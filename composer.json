{
    "name": "mqondisi/laravel-module-generator",
    "description": "Opinionated Laravel 10 / 11 module scaffolding (model, migration, repository, DTO, optional DAO, controllers)",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/console": "^10.0|^11.0",
        "illuminate/contracts": "^10.0|^11.0",
        "illuminate/filesystem": "^10.0|^11.0",
        "illuminate/support": "^10.0|^11.0",
        "spatie/laravel-data": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Mqondisi\\ModuleGenerator\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mqondisi\\ModuleGenerator\\ModuleGeneratorServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
