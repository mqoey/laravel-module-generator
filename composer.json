{
    "name": "mqondisi/laravel-module-generator",
    "description": "Opinionated Laravel 9–13 module scaffolding (model, migration, repository, DTO, optional DAO, controllers)",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/console": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/contracts": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "spatie/laravel-data": "^4.0"
    },
    "suggest": {
        "spatie/laravel-data": "Install in your app (^4.0 for Laravel 11–13) so generated DTO stubs under app/Data resolve."
    },
    "autoload": {
        "psr-4": {
            "Mqondisi\\ModuleGenerator\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mqondisi\\ModuleGenerator\\ModuleGeneratorServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
